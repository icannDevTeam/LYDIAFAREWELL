# Firebase Web SDK config (client-safe — these are public keys)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx

# Public base URL of the deployed site (used to generate the QR code).
# In local dev you can leave this blank and use your LAN IP, e.g. http://192.168.1.42:3000
NEXT_PUBLIC_SITE_URL=https://lydia-farewell.vercel.app
